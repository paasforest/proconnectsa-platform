# Copy this to Railway → Variables tab

# Django core
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=False
ALLOWED_HOSTS=your-railway-domain.railway.app,api.proconnectsa.co.za

# Database — Railway provides this automatically when you add PostgreSQL addon
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend
FRONTEND_URL=https://www.proconnectsa.co.za

# Email (Resend)
RESEND_API_KEY=re_your_key_here
DEFAULT_FROM_EMAIL=noreply@proconnectsa.co.za
SUPPORT_EMAIL=support@proconnectsa.co.za
ADMIN_EMAIL=admin@proconnectsa.co.za

# SMS (Panacea)
PANACEA_SMS_USERNAME=your_username
PANACEA_SMS_PASSWORD=your_password
SMS_SENDER_ID=ProConnectSA

# Google OAuth
GOOGLE_OAUTH2_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH2_CLIENT_SECRET=your_google_client_secret

# PayPal
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Lead settings
DEFAULT_CREDIT_PRICE=70
UNLOCK_MODE=hybrid
RESERVATION_EXPIRY_HOURS=24

# Optional: Sentry error tracking (free tier available)
SENTRY_DSN=
